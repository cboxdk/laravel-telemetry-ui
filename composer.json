{
    "name": "cboxdk/laravel-telemetry-ui",
    "description": "Laravel-native observability UI for cboxdk/laravel-telemetry: query Tempo, Loki and Prometheus/Mimir directly and visualize your apps with extensible Livewire cards.",
    "keywords": [
        "cbox",
        "laravel",
        "telemetry",
        "observability",
        "dashboard",
        "tempo",
        "loki",
        "prometheus",
        "mimir",
        "grafana",
        "livewire"
    ],
    "homepage": "https://github.com/cboxdk/laravel-telemetry-ui",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/cboxdk/laravel-telemetry-ui/issues",
        "source": "https://github.com/cboxdk/laravel-telemetry-ui"
    },
    "authors": [
        {
            "name": "Sylvester Damgaard",
            "email": "sn@cbox.dk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4|^8.5",
        "cboxdk/laravel-telemetry": "^0.1.0-alpha.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/mcp": "~0.8.2",
        "livewire/livewire": "^3.6"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Cbox\\TelemetryUi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\TelemetryUi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cbox\\TelemetryUi\\TelemetryUiServiceProvider"
            ],
            "aliases": {
                "TelemetryUi": "Cbox\\TelemetryUi\\Facades\\TelemetryUi"
            }
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "check": [
            "@format:check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
